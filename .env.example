# Copy this file to .env and fill in values for local development.
# .env is sourced automatically by scripts/bootstrap.sh.
# Never commit .env — it is listed in .gitignore.

# GitHub token — used as GHCR token if --ghcr-token is not passed
GITHUB_TOKEN=

# Infisical Universal Auth (required when using --infisical-project)
INFISICAL_UNIVERSAL_AUTH_CLIENT_ID=
INFISICAL_UNIVERSAL_AUTH_CLIENT_SECRET=

# Linode API token (required when using --external-dns)
LINODE_TOKEN=

# Ngrok credentials (required when using --ngrok)
NGROK_API_KEY=
NGROK_AUTHTOKEN=

# Authelia admin password (required when using --authelia)
AUTHELIA_ADMIN_PASSWORD=

# Grafana Cloud credentials (kubernetes backend only — seeded into local-secrets)
GCLOUD_K8S_RW_TOKEN=
GCLOUD_HOSTED_LOGS_ID=
GCLOUD_HOSTED_METRICS_ID=
